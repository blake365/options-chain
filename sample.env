# =================================================================
# Data provider selection
# =================================================================
# Optional. Explicit: "tradier" or "alpaca".
# If unset, Alpaca is used when ALPACA_API_KEY_ID + ALPACA_SECRET_KEY
# are set, otherwise Tradier.
DATA_PROVIDER=tradier

# =================================================================
# Tradier (sandbox)
# =================================================================
TRADIER_TOKEN=your_tradier_sandbox_token_here
# Optional. Override if pointing at live Tradier.
# TRADIER_BASE_URL=https://api.tradier.com/v1

# =================================================================
# Alpaca (paper account works fine for market data)
# =================================================================
# ALPACA_API_KEY_ID=your_alpaca_key_id
# ALPACA_SECRET_KEY=your_alpaca_secret
# Optional feed overrides. Defaults: indicative (options), iex (stocks).
# ALPACA_OPTIONS_FEED=indicative   # or opra (paid)
# ALPACA_STOCK_FEED=iex            # or delayed_sip, or sip (paid)
# ALPACA_TRADING_BASE=https://paper-api.alpaca.markets

# =================================================================
# Worker-only (not used by stdio entrypoint)
# =================================================================
# Set via `wrangler secret put APPROVE_PASSCODE` — used on the
# consent page when an MCP client completes its OAuth flow.
# APPROVE_PASSCODE=generate_a_long_random_string
