{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "options-chain-mcp",
	"main": "src/worker.ts",
	"compatibility_date": "2025-04-01",
	"compatibility_flags": ["nodejs_compat"],
	"durable_objects": {
		"bindings": [
			{
				"name": "MCP_OBJECT",
				"class_name": "OptionsChainMCP"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["OptionsChainMCP"]
		}
	],
	"observability": {
		"enabled": true
	}
}
